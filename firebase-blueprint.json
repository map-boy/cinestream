{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences, watch history, and favorites.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "myList": {
          "type": "array",
          "items": { "type": "string" },
          "description": "A list of movie IDs the user has saved."
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "movieId": { "type": "string" },
              "watchedAt": { "type": "integer" },
              "progress": { "type": "number" }
            }
          },
          "description": "The user's watch history."
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    }
  }
}
